{
  "rewrites": [
    { "source": "/mobile", "destination": "/" },
    { "source": "/mobile/(.*)", "destination": "/" },
    { "source": "/inventario-mobile", "destination": "/" },
    { "source": "/inventario-mobile/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}